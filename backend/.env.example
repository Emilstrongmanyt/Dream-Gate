# Copy to backend/.env and fill in values from your Supabase project dashboard.
# API keys: Project Settings -> API (NOT the database connection string)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password

# Public URL of the authoritative match server (HTTP + WebSocket)
MATCH_SERVER_URL=http://localhost:8787

# Used when deploying edge functions
PROJECT_REF=your-project-ref

# Unity Gaming Services bridge for Supabase sessions (edge function ugs-session)
UNITY_PROJECT_ID=fbdba5bf-6cda-4d17-a13a-2eb5609c2dff
UGS_BRIDGE_SECRET=generate-a-long-random-secret